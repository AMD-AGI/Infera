bench/**/results/*.csv
bench/**/results/*.png
bench/**/results/*.svg
bench/**/results/*.md
bench/**/results/*.json
bench/kv_cache_cliff/results/

# Vendored third-party sources (UCX / RIXL) — too large, fetch/build on demand
deploy/docker/third_party/

# Local scratch — not for review.
.review-drafts/
temp/
.spur_job_*.sh
.spur_ns_*.sh
spur-*.out

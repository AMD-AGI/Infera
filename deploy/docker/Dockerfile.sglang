# Infera SGLang engine image: layers the infera source onto the ROCm SGLang
# base and sets an entrypoint that injects the host's libionic before exec'ing
# the command.
ARG SGLANG_BASE_IMAGE=lmsysorg/sglang-rocm:v0.5.13-rocm720-mi35x-20260612
FROM ${SGLANG_BASE_IMAGE}

# ---- Mooncake (main + B-group C++ patches) --------------------------------
# WHY: the SGLang base bundles Mooncake v0.3.7.post2, whose HIP GPU MR path is
# bare ibv_reg_mr (it only has the dma-buf verb under USE_CUDA). On a dma-buf-only
# RoCE fabric (no ib_peer_mem) bare ibv_reg_mr can't pin VRAM and the PD KV
# registration OOMs. Rebuild Mooncake from the same pinned main ref vLLM uses,
# with MOONCAKE_HIP_DMABUF selecting the GPU MR path (see build_mooncake_rocm.sh /
# Dockerfile.vllm). ONLY rebuilt when MOONCAKE_HIP_DMABUF=1 (the e2e disagg harness
# passes it for dma-buf-only clusters); by default (=0) the base image's Mooncake
# is used UNCHANGED — so PD-mixed / any non-dma-buf build is byte-for-byte as before
# (SGLang's base already ships a working ROCm Mooncake, unlike the CUDA-only vLLM base).
ARG BUILD_MOONCAKE=1
ARG MOONCAKE_GIT_REF=747003c058015c4077a266e7ccd7549bbc9baede
ARG MOONCAKE_HIP_DMABUF=0
COPY deploy/docker/scripts/build_mooncake_rocm.sh /tmp/build_mooncake_rocm.sh
COPY deploy/docker/patches/mooncake_cpp/ /tmp/mooncake_cpp/
RUN if [ "${BUILD_MOONCAKE}" = "1" ] && [ "${MOONCAKE_HIP_DMABUF}" = "1" ]; then \
        MOONCAKE_DMABUF=1 MOONCAKE_HIP_DMABUF=1 \
        MOONCAKE_GIT_REF="${MOONCAKE_GIT_REF}" \
        MC_CPP_PATCH_DIR=/tmp/mooncake_cpp \
        bash /tmp/build_mooncake_rocm.sh; \
    else \
        echo "MOONCAKE_HIP_DMABUF=0 — using the base image's Mooncake (unchanged)"; \
    fi \
    && rm -rf /tmp/build_mooncake_rocm.sh /tmp/mooncake_cpp

WORKDIR /opt/infera

# Install infera + its declared deps from pyproject (single source of truth).
# The base already ships torch/sglang and most of infera's runtime stack; pip
# leaves those satisfied versions untouched and only pulls what's missing (e.g.
# nats-py). `.[sglang]` = infera core + the EPP (gaie) deps so this image can
# also run `python -m infera.gaie`.
COPY pyproject.toml README.md ./
COPY infera ./infera
RUN pip install --no-cache-dir ".[sglang]"

# ---- Rust router (multi-core data plane; --router-backend rust) ----
# The ROCm base ships cargo; use it (install a minimal toolchain only if
# absent). Needs cc for linking and libclang (onig_sys/bindgen). Removes
# the build tree, keeps the binary.
COPY rust ./rust
RUN set -eu; \
    command -v cc >/dev/null || { apt-get update && apt-get install -y --no-install-recommends build-essential && rm -rf /var/lib/apt/lists/*; }; \
    export LIBCLANG_PATH="$(dirname "$(find /opt/rocm* /usr/lib /usr/lib64 -name 'libclang.so*' 2>/dev/null | head -1)")"; \
    case "$LIBCLANG_PATH" in ""|".") apt-get update && apt-get install -y --no-install-recommends libclang-dev && rm -rf /var/lib/apt/lists/* && export LIBCLANG_PATH="$(dirname "$(find /usr/lib -name 'libclang.so*' 2>/dev/null | head -1)")";; esac; \
    command -v cargo >/dev/null || { curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | sh -s -- -y --profile minimal; . "$HOME/.cargo/env"; }; \
    export PATH="$HOME/.cargo/bin:$PATH"; \
    export LIBCLANG_PATH="${LIBCLANG_PATH:-/opt/rocm/llvm/lib}"; \
    ( cd rust && cargo build --release --bin infera-router ); \
    cp rust/target/release/infera-router /usr/local/bin/infera-router; \
    rm -rf rust

COPY deploy/docker/scripts/infera_inject_host_ionic.sh /usr/local/bin/infera-inject-host-ionic

ENTRYPOINT ["/usr/local/bin/infera-inject-host-ionic"]
CMD ["/bin/bash"]

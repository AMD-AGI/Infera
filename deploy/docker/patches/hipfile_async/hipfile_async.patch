+# ---------------------------------------------------------------------------
+#  Async I/O (stream-attached) — wraps hipFile{Read,Write}Async +
+#  hipFileStream{Register,Deregister}. Mirrors the cuFile async pattern.
+# ---------------------------------------------------------------------------
+
+
+def hipFileWriteAsync(uintptr_t handle, uintptr_t buffer_base, size_t size,
+                      _c.hoff_t file_offset, _c.hoff_t buffer_offset,
+                      uintptr_t stream_handle):
+    """Wrapper for ``hipFileWriteAsync``. Submits the I/O to the given
+    CUDA/HIP stream and returns immediately. Caller MUST sync on the
+    stream (e.g. via ``cuda.Event.record()`` + downstream
+    ``stream.wait_event()`` or ``stream.synchronize()``) before reading
+    ``bytes_done``.
+
+    ``stream_handle`` is the integer handle from
+    ``torch.cuda.Stream.cuda_stream`` (or any opaque ``hipStream_t``).
+
+    Returns ``(bytes_done, extra)``:
+      * On submit success: ``(bytes_done, 0)``. ``bytes_done`` is
+        updated by the driver after the async op completes.
+      * On submit error: ``(-error_code, extra)`` where ``error_code``
+        is ``hipFileOpError_t`` (positive integer) and ``extra`` is
+        ``errno`` (for sys errors) or ``hipError_t`` (for HIP driver
+        errors).
+    """
+    cdef _c.hipFileError_t ret
+    cdef size_t size_io = size
+    cdef _c.hoff_t file_off_io = file_offset
+    cdef _c.hoff_t buf_off_io = buffer_offset
+    cdef ssize_t bytes_done = 0
+    cdef int extra = 0
+    with nogil:
+        ret = _c.hipFileWriteAsync(
+            <_c.hipFileHandle_t>handle,
+            <const void *>buffer_base,
+            &size_io, &file_off_io, &buf_off_io, &bytes_done,
+            <_c.hipStream_t>stream_handle,
+        )
+        if <int>ret.err != <int>_c.hipFileSuccess:
+            if <int>ret.err == <int>_c.hipFileHipDriverError:
+                extra = <int>ret.hip_drv_err
+            else:
+                extra = errno
+    if <int>ret.err != <int>_c.hipFileSuccess:
+        return (-<int>ret.err, extra)
+    return (bytes_done, 0)
+
+
+def hipFileReadAsync(uintptr_t handle, uintptr_t buffer_base, size_t size,
+                     _c.hoff_t file_offset, _c.hoff_t buffer_offset,
+                     uintptr_t stream_handle):
+    """Mirror of ``hipFileWriteAsync`` for reads. See docstring above
+    for return semantics."""
+    cdef _c.hipFileError_t ret
+    cdef size_t size_io = size
+    cdef _c.hoff_t file_off_io = file_offset
+    cdef _c.hoff_t buf_off_io = buffer_offset
+    cdef ssize_t bytes_done = 0
+    cdef int extra = 0
+    with nogil:
+        ret = _c.hipFileReadAsync(
+            <_c.hipFileHandle_t>handle,
+            <void *>buffer_base,
+            &size_io, &file_off_io, &buf_off_io, &bytes_done,
+            <_c.hipStream_t>stream_handle,
+        )
+        if <int>ret.err != <int>_c.hipFileSuccess:
+            if <int>ret.err == <int>_c.hipFileHipDriverError:
+                extra = <int>ret.hip_drv_err
+            else:
+                extra = errno
+    if <int>ret.err != <int>_c.hipFileSuccess:
+        return (-<int>ret.err, extra)
+    return (bytes_done, 0)
+
+
+def hipFileStreamRegister(uintptr_t stream_handle, int flags=0):
+    """Wrapper for ``hipFileStreamRegister``. Register a CUDA/HIP
+    stream with hipFile so async I/O calls can target it. Must be
+    called BEFORE any ``hipFile{Read,Write}Async`` call on the stream.
+
+    ``flags`` is reserved (pass 0). Returns ``int(hipFileError_t)`` —
+    ``hipFileSuccess`` (0) on success, negative on failure.
+    """
+    cdef _c.hipFileError_t ret
+    with nogil:
+        ret = _c.hipFileStreamRegister(<_c.hipStream_t>stream_handle, flags)
+    return int(ret.err)
+
+
+def hipFileStreamDeregister(uintptr_t stream_handle):
+    """Wrapper for ``hipFileStreamDeregister``. Unregister a stream
+    previously registered with ``hipFileStreamRegister``. Idempotent
+    in the binding (driver may or may not be idempotent — check rc).
+
+    Returns ``int(hipFileError_t)``.
+    """
+    cdef _c.hipFileError_t ret
+    with nogil:
+        ret = _c.hipFileStreamDeregister(<_c.hipStream_t>stream_handle)
+    return int(ret.err)
+
+
+def supports_async():
+    """Quick probe: returns True if hipFileStreamRegister against a
+    null stream returns either hipFileSuccess or
+    ``hipFileInvalidValue`` (null stream rejected — driver supports
+    the API). Returns False if the driver returns
+    ``hipFileAsyncNotSupported`` (5038) or any other failure code,
+    indicating the underlying ``libhipfile.so`` doesn't implement the
+    async path."""
+    cdef _c.hipFileError_t ret
+    with nogil:
+        ret = _c.hipFileStreamRegister(<_c.hipStream_t>0, 0)
+    return <int>ret.err != 5038
+
+

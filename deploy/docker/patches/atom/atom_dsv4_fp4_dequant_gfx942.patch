diff --git a/atom/model_ops/moe.py b/atom/model_ops/moe.py
index ff4bfc12..cd438b1c 100644
--- a/atom/model_ops/moe.py
+++ b/atom/model_ops/moe.py
@@ -2204,8 +2204,131 @@ class FusedMoE(torch.nn.Module):
         self.layer_name = prefix
 
     def process_weights_after_loading(self):
+        self._maybe_dequant_fp4_to_fp8()
         self._online_quant()
 
+    def _maybe_dequant_fp4_to_fp8(self):
+        """gfx942/CDNA3: convert FP4 (e2m1 + ue8m0) routed experts -> FP8 e4m3
+        block (per_1x128) at load, then run aiter's FP8 blockscale MoE.
+
+        CDNA3 has no working FP4 MoE kernel (aiter mxgemm is gfx950-only; ATOM's
+        triton path needs the absent triton_kernels.routing). aiter's FP8
+        blockscale MoE works on gfx942 (validated SNR ~24dB), so we dequant the
+        loaded FP4 expert buffers to FP8 here and swap quant_method to
+        Fp8MoEMethod. Env-gated (ATOM_DSV4_FP4_DEQUANT); no-op on gfx950.
+
+        Mirrors _online_quant's per-expert dequant->requant->method-swap, but the
+        source is FP4 (per_1x32, packed uint8 + e8m0 scale) rather than fp8/bf16.
+        Runs before the loader calls the (now FP8) quant_method's
+        process_weights_after_loading, so fnuz-normalize + shuffle happen on FP8.
+        """
+        if not envs.ATOM_DSV4_FP4_DEQUANT:
+            return
+        if self.layer_quant_config is None:
+            return
+        if self.layer_quant_config.quant_dtype != dtypes.fp4x2:
+            return
+        if not isinstance(self.quant_method, Mxfp4MoEMethod):
+            return
+
+        from atom.model_ops.quant_v4 import dequant_fp4_e2m1
+
+        src = self.quant_method
+        fp4_block = 32
+        # Real (unpadded) sizes for this TP partition.
+        inter = self.intermediate_size_per_partition
+        hidden = self.hidden_size
+        num_local = self.local_num_experts
+        device = self.w13_weight.data.device
+
+        # Padded layout of the loaded FP4 buffers (see Mxfp4MoEMethod.create_weights):
+        #   w13_weight [E, 2*inter_pad, hidden/2] uint8; w1 rows [0:inter],
+        #     w3 rows [inter_pad : inter_pad+inter]  (inter_pad = src.intermediate_size)
+        #   w13_weight_scale [E, 2*inter_pad, hidden/32] e8m0(as uint8)
+        #   w2_weight [E, hidden, inter_pad/2] uint8; real cols [0:inter/2]
+        #   w2_weight_scale [E, hidden, inter_pad/32] e8m0(as uint8); real [0:inter/32]
+        inter_pad = src.intermediate_size
+
+        old_w13 = self.w13_weight.data
+        old_w13_s = self.w13_weight_scale.data
+        old_w2 = self.w2_weight.data
+        old_w2_s = self.w2_weight_scale.data
+
+        def _deq_w13(e, lo):
+            # unpack+dequant one gate/up half [inter, hidden] for expert e.
+            packed = old_w13[e, lo : lo + inter, :].view(torch.int8)
+            scale = old_w13_s[e, lo : lo + inter, :].view(torch.float8_e8m0fnu)
+            return dequant_fp4_e2m1(packed, scale, fp4_block, torch.bfloat16)
+
+        # Build the target FP8-block method + buffers.
+        fp8_spec = LayerQuantConfig(
+            quant_type=QuantType.per_1x128, quant_dtype=dtypes.fp8
+        )
+        new_method = Fp8MoEMethod(fp8_spec, self.moe_config)
+        self.layer_quant_config = fp8_spec
+        self.quant_method = new_method
+        self.moe_quant_params["params_dtype"] = dtypes.fp8
+        with torch.device(device):
+            new_method.create_weights(layer=self, **self.moe_quant_params)
+        self.w13_input_scale = None
+        self.w2_input_scale = None
+
+        # Quantize to e4m3fn (buffer dtype from create_weights, moe.py:1591).
+        # Fp8MoEMethod._process_block_quant then normalizes fn->fnuz (doubles
+        # scale, fixes NaN bit) for the gfx942 aiter kernel — so we MUST produce
+        # e4m3fn here, not fnuz, or the scale would be double-corrected.
+        fp8_dtype = torch.float8_e4m3fn
+        fp8_max = torch.finfo(fp8_dtype).max  # 448.0
+
+        def _quant_block_128x128(w_bf16):
+            """BF16 [out, in] -> (fp8_e4m3fn [out,in], fp32 scale
+            [ceil(out/128),ceil(in/128)]). 128x128 block scale, matching
+            Fp8MoEMethod's block buffer + aiter fmoe_fp8_blockscale_g1u1 kernel."""
+            out, inn = w_bf16.shape
+            bn = (out + 127) // 128
+            bk = (inn + 127) // 128
+            pad_o = bn * 128 - out
+            pad_i = bk * 128 - inn
+            wf = w_bf16.float()
+            if pad_o or pad_i:
+                wf = torch.nn.functional.pad(wf, (0, pad_i, 0, pad_o))
+            blocks = wf.reshape(bn, 128, bk, 128)
+            amax = blocks.abs().amax(dim=(1, 3), keepdim=True).clamp(min=1e-8)
+            scale = (amax / fp8_max)
+            q = (blocks / scale).clamp(-fp8_max, fp8_max).to(fp8_dtype)
+            q = q.reshape(bn * 128, bk * 128)[:out, :inn].contiguous()
+            return q, scale.reshape(bn, bk).contiguous()
+
+        for e in range(num_local):
+            # w13 (column-parallel): dequant w1 & w3 halves, requant to fp8 block.
+            w1_bf16 = _deq_w13(e, 0).to(device)
+            w3_bf16 = _deq_w13(e, inter_pad).to(device)
+            w1_q, w1_s = _quant_block_128x128(w1_bf16)
+            w3_q, w3_s = _quant_block_128x128(w3_bf16)
+            del w1_bf16, w3_bf16
+            # w13 buffer: [2*inter, hidden] weight; [2*ceil(inter/128), ceil(hidden/128)] scale.
+            bn = w1_s.shape[0]
+            self.w13_weight.data[e, 0:inter, :].copy_(w1_q)
+            self.w13_weight.data[e, inter:2 * inter, :].copy_(w3_q)
+            self.w13_weight_scale.data[e, 0:bn, :].copy_(w1_s)
+            self.w13_weight_scale.data[e, bn:2 * bn, :].copy_(w3_s)
+            del w1_q, w3_q, w1_s, w3_s
+
+            # w2 (row-parallel): real cols [0:inter/2] packed -> [hidden, inter].
+            w2_packed = old_w2[e, :, : inter // 2].view(torch.int8)
+            w2_scale = old_w2_s[e, :, : inter // fp4_block].view(torch.float8_e8m0fnu)
+            w2_bf16 = dequant_fp4_e2m1(
+                w2_packed, w2_scale, fp4_block, torch.bfloat16
+            ).to(device)
+            w2_q, w2_s = _quant_block_128x128(w2_bf16)
+            del w2_bf16
+            self.w2_weight.data[e].copy_(w2_q)
+            self.w2_weight_scale.data[e].copy_(w2_s)
+            del w2_q, w2_s
+
+        del old_w13, old_w13_s, old_w2, old_w2_s
+        torch.cuda.empty_cache()
+
     def _online_quant(self):
         """Handle online quantization: (optionally dequant →) quantize weights,
         then switch quant_method.
